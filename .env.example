# Database Connection
# Replace with valid PostgreSQL credentials before running the app.
DATABASE_URL="postgresql://hostpulse:hostpulse@localhost:5432/hostpulse?schema=public"

# JWT Secret (change in production!)
JWT_ACCESS_SECRET="hostpulse-dev-jwt-secret-please-change"

# Frontend API proxy target for Next rewrites (defaults to this value)
NEXT_PUBLIC_API_PROXY="http://127.0.0.1:3000/api"

# Firebase Web SDK Configuration
NEXT_PUBLIC_FIREBASE_API_KEY="your-firebase-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="000000000000"
NEXT_PUBLIC_FIREBASE_APP_ID="1:000000000000:web:replace-with-app-id"
NEXT_PUBLIC_FIREBASE_DATABASE_URL=""
NEXT_PUBLIC_FIREBASE_ENABLED="false"

# API Port
PORT=3000

# NOTE: API keys/tokens should not be committed. If you had a token here it
# was moved to `.env.bak` and replaced with this placeholder. Set real keys
# in your environment or in a secure secrets manager.




# Safaricom Daraja M-Pesa Configuration
# Get credentials from: https://developer.safaricom.co.ke
MPESA_ENVIRONMENT=sandbox  # Change to 'production' for live
MPESA_CONSUMER_KEY=your_daraja_consumer_key_here
MPESA_CONSUMER_SECRET=your_daraja_consumer_secret_here
MPESA_SHORTCODE=your_shortcode_here
MPESA_PASSKEY=your_passkey_here
MPESA_CALLBACK_URL=http://localhost:3000/api/payments/mpesa/webhook
MPESA_WEBHOOK_SECRET="hostpulse-dev-webhook-secret-please-change"

# B2C Payout Configuration (for host payouts)
MPESA_INITIATOR_NAME=your_initiator_name
MPESA_SECURITY_CREDENTIAL=your_security_credential
MPESA_RESULT_URL=http://localhost:3000/api/payments/mpesa/b2c-result
MPESA_QUEUE_TIMEOUT_URL=http://localhost:3000/api/payments/mpesa/b2c-timeout

# API Base URL (update for production)
API_BASE_URL=http://localhost:3000
