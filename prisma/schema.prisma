// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  hashedPassword String
  phone          String?
  firstName      String?
  lastName       String?
  name           String?   // Full name field
  role           String    @default("guest") // "guest" or "host"
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  properties Property[] @relation("HostProperties")
  bookings   Booking[]
  revenueRecords RevenueRecord[]

  listingsCreated   Listing[] @relation("UserListingsCreated")
  listingsClaimed   Listing[] @relation("UserListingsClaimed")
  listingsVerified  Listing[] @relation("UserListingsVerified")

  @@index([role])
}

model Property {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  location    Json?     // GeoJSON format
  amenities   String[]
  price       Float
  photos      String[]
  hostId      Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  host     User      @relation("HostProperties", fields: [hostId], references: [id])
  bookings Booking[]
  revenueRecords RevenueRecord[]

  @@index([hostId])
  @@index([createdAt])
}


model Payment {
  id              Int       @id @default(autoincrement())
  bookingId       Int
  amount          Float
  method          String    @default("mpesa") // "mpesa", "card", etc.
  status          String    @default("pending") // "pending", "success", "failed"
  mpesaTxId       String?   @unique
  phoneNumber     String?
  receiptNumber   String?
  transactionDate DateTime?
  resultCode      String?
  resultDesc      String?
  processedAt     DateTime?
  idempotencyKey  String?   @unique
  
  // Escrow fields
  escrowReleased  Boolean   @default(false)
  escrowHeldUntil DateTime?
  escrowReleasedAt DateTime?
  escrowReleasedBy Int?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId, status])
  @@index([processedAt])
  @@index([receiptNumber])
}

model RevenueRecord {
  id                Int       @id @default(autoincrement())
  bookingId         Int       @unique
  hostId            Int
  propertyId        Int
  grossAmount       Decimal   @db.Decimal(10, 2)
  commission        Decimal   @db.Decimal(10, 2)
  vat               Decimal   @db.Decimal(10, 2)
  netAmount         Decimal   @db.Decimal(10, 2)
  payoutStatus      String    @default("pending") // "pending", "processing", "paid", "failed"
  payoutDate        DateTime?
  payoutTransactionId String?
  payoutError       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  host     User      @relation(fields: [hostId], references: [id])
  property Property  @relation(fields: [propertyId], references: [id])
  booking  Booking   @relation(fields: [bookingId], references: [id])

  @@index([hostId, payoutStatus])
  @@index([createdAt])
}

model Booking {
  id        Int      @id @default(autoincrement())
  userId   Int
  propertyId Int
  startDate DateTime
  endDate   DateTime
  total     Float
  commission Float?  // Optional commission override
  status    String   @default("pending") // "pending", "confirmed", "cancelled"
  dates     Json?    // Flexible date storage
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  property Property  @relation(fields: [propertyId], references: [id])
  payments Payment[]
  revenueRecords RevenueRecord[]

  @@index([userId])
  @@index([propertyId, status, startDate, endDate])
}

enum ListingCategory {
  hotel
  lodge
  resort
  airbnb
  tour_company
}

enum SourceType {
  google_places
}

model Location {
  id        String @id @default(uuid())
  name      String?
  addressLine1 String?
  city      String?
  county    String?
  country   String  @default("Kenya")

  latitude  Float
  longitude Float

  // Bounding-box friendly indexes (used for fast "nearby" prefiltering).
  @@index([latitude])
  @@index([longitude])
  @@index([latitude, longitude])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings  Listing[]
}

model Listing {
  id          String          @id @default(uuid())
  name        String
  category    ListingCategory
  description String?

  phone       String?
  websiteUrl  String?

  // Aggregated rating summary (can be refreshed by background jobs).
  ratingAvg   Float?
  ratingCount Int?

  isVerified      Boolean   @default(false)
  verificationNote String?

  createdByUserId Int?
  claimedByUserId Int?
  verifiedByUserId Int?

  locationId String @unique
  location   Location @relation(fields: [locationId], references: [id])

  sources    Source[]
  reviews    Review[]
  media      Media[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  createdByUser  User? @relation("UserListingsCreated", fields: [createdByUserId], references: [id])
  claimedByUser  User? @relation("UserListingsClaimed", fields: [claimedByUserId], references: [id])
  verifiedByUser User? @relation("UserListingsVerified", fields: [verifiedByUserId], references: [id])

  @@index([category])
  @@index([createdAt])
}

model Source {
  id String @id @default(uuid())

  type SourceType
  provider String?
  providerPlaceId String

  query String?
  rawTypes String[]
  placeUrl String?

  rating Float?
  ratingCount Int?

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id])

  reviews   Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, providerPlaceId])
  @@index([listingId])
}

model Review {
  id String @id @default(uuid())

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id])

  sourceId String?
  source   Source?  @relation(fields: [sourceId], references: [id])

  authorName String?
  rating Float
  text String?
  publishedAt DateTime?

  createdAt DateTime @default(now())

  @@index([listingId])
  @@index([rating])
}

model Media {
  id String @id @default(uuid())

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id])

  url String
  type String?

  providerPhotoRef String?
  sortOrder Int?

  createdAt DateTime @default(now())

  @@index([listingId])
}
