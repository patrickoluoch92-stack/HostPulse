{
  "version": "0.2.0",
  "configurations": [
    
    


    {
      "name": "Launch Chrome",
      "request": "launch",
      "type": "chrome",
      "url": "http://localhost:8080",
      "webRoot": "${workspaceFolder}"
    },
    
    

    {
      "type": "node",
      "request": "launch",
      "name": "Run ansi-html",
      "runtimeExecutable": "ansi-html",
      "cwd": "${workspaceFolder}",
      "args": []
    },
    {
      "name": "Launch Chrome (remote-debugging)",
      "request": "launch",
      "type": "chrome",
      "url": "http://127.0.0.1:4200",
      "webRoot": "${workspaceFolder}",
      "runtimeExecutable": "chrome",
      "preLaunchTask": "start-frontend",
      "runtimeArgs": [
        "--remote-debugging-port=9222",
        "--user-data-dir=${workspaceFolder}/.vscode/chrome-debug-profile",
        "--no-first-run",
        "--new-window"
      ]
    },
    {
      "name": "Attach to Chrome (9222)",
      "port": 9222,
      "request": "attach",
      "type": "chrome",
      "url": "http://127.0.0.1:4200",
      "webRoot": "${workspaceFolder}",
      "timeout": 20000
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug API (NestJS)",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--inspect"
      ],
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/api/src/main.ts",
      "outFiles": [
        "${workspaceFolder}/api/dist/**/*.js"
      ],
      "sourceMaps": true,
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug API (Built)",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--inspect"
      ],
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/api/dist/main.js",
      "sourceMaps": true,
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal",
      "preLaunchTask": "build-api"
    }
  ]
}